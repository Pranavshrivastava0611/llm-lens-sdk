{
  "name": "llm-lens-sdk",
  "version": "0.1.0",
  "description": "Sub-millisecond, local-first OpenTelemetry observability SDK for LLMs. Features native Vercel AI SDK integration.",
  "author": "Pranav Shrivastava",
  "keywords": [
    "llm",
    "observability",
    "opentelemetry",
    "ai",
    "vercel",
    "langchain",
    "openai",
    "telemetry",
    "tracing",
    "debugging"
  ],
  "homepage": "https://github.com/Pranavshrivastava0611/llm-lens-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pranavshrivastava0611/llm-lens-sdk.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Pranavshrivastava0611/llm-lens-sdk/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1"
  }
}
