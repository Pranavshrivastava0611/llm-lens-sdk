{
  "name": "llm-lens-daemon",
  "version": "0.1.2",
  "description": "The background daemon and local SQLite dashboard for LLM Lens. Receives ultra-low latency OpenTelemetry spans.",
  "author": "Pranav Shrivastava",
  "keywords": [
    "llm",
    "observability",
    "opentelemetry",
    "daemon",
    "sqlite",
    "dashboard",
    "tracing"
  ],
  "homepage": "https://github.com/Pranavshrivastava0611/llm-lens-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pranavshrivastava0611/llm-lens-sdk.git",
    "directory": "packages/daemon"
  },
  "bugs": {
    "url": "https://github.com/Pranavshrivastava0611/llm-lens-sdk/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "llm-lens": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rm -rf ui && cp -r ../dashboard/out ui",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist ui"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/openai": "^3.0.74",
    "ai": "^6.0.208",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "llm-lens-dashboard": "*",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "ui"
  ],
  "license": "MIT"
}
