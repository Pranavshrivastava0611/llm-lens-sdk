{
  "name": "llm-lens",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "example"
  ],
  "packageManager": "npm@10.8.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "start": "node packages/daemon/dist/cli.js dashboard --port 8493",
    "test:example": "npm run start --workspace=example-app"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
